# ============================================================
# SUNFALL ARENA — variáveis de ambiente do servidor
# Em produção, configure via secrets do Fly:
#   fly secrets set DISCORD_WEBHOOK_URL="https://discord.com/api/webhooks/..."
# ============================================================

# Postgres (Railway)
DATABASE_URL=

# Assinatura dos tokens de sessão (JWT)
JWT_SECRET=

# Webhook do Discord que recebe sugestões e reportes de bug da
# Central da Comunidade. Sem ele o jogo funciona normalmente —
# os envios ficam apenas registrados no banco.
DISCORD_WEBHOOK_URL=

# Origens permitidas no CORS (separadas por vírgula)
CORS_ORIGIN=http://localhost:3000
